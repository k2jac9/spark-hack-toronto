# Ruflo / claude-flow local tooling (machine-local, regenerate with `ruflo init`)
.claude/
.mcp.json
.swarm/
.claude-flow/
claude-flow.config.json
data/memory/
agentdb.rvf
agentdb.rvf.lock
*.rvf
*.rvf.lock
ruvector.db
*.db

# Secrets / env
.env
.env.*
# committed onboarding template (placeholders only)
!.env.example
*.key
*.pem

# OS / editor
.DS_Store
*.swp

# Python
__pycache__/
*.py[cod]
.venv/
.venv-linux/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Local dev stack runtime (make dev): background app/ollama PIDs + logs.
.dev/

# Rust (Urban-OS native accelerator) — build output only; Cargo.lock IS committed
# for a reproducible aarch64 build on the box.
native/target/
*.so

# Node (in case agentic-flow/tooling gets linked locally)
node_modules/
package.json
package-lock.json

# Downloaded open-data files (fetched via scripts/download_data.py)
data/raw/
data/cache/

# RAPIDS GPU runtime logs (cuFile / kvikio GPU Direct Storage) — written by the
# GPU stack on the box; not source. See requirements-gpu.txt / ADR-0024.
cufile.log

# Local UI-verification artifacts (Playwright MCP snapshots + before/after shots).
# Captured to validate UX PRs; evidence, not source — kept out of the repo.
.playwright-mcp/
before-*.png
after-*.png
baseline-*.png
