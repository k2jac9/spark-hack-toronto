#!/usr/bin/env bash
# Pre-push hook: refuse to push if the test suite is red.
# Shared via the repo (scripts/hooks/) — install once with: make install-hooks
# Bypass in a real emergency only: git push --no-verify
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "[pre-push] running tests…"

# Prefer the project venv if present, else fall back to system python.
if [ -x ".venv/bin/pytest" ]; then
  PYTHONPATH=src .venv/bin/pytest -q
elif command -v pytest >/dev/null 2>&1; then
  PYTHONPATH=src pytest -q
else
  echo "[pre-push] pytest not found — install deps (make install) or use --no-verify." >&2
  exit 1
fi

echo "[pre-push] tests green — pushing."
